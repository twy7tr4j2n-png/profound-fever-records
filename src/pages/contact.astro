---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Profound Fever Records">
  <main class="contact-page">

    <div class="contact-wrap">
      <p class="contact-label">Profound Fever Records</p>
      <h1 class="contact-heading">Get in touch</h1>

      <form class="contact-form" action="https://formspree.io/f/xykqkynl" method="POST">
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required autocomplete="off" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="off" />
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit">Send</button>
      </form>
    </div>

  </main>
</BaseLayout>

<style>
  .contact-page {
    min-height: 100vh;
    background: radial-gradient(ellipse at center, var(--black) 0%, var(--purple-edge) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 24px 80px;
  }

  .contact-wrap {
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .contact-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  .contact-heading {
    font-family: var(--font-serif);
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--white);
    line-height: 1;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 8px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  input, textarea {
    background: transparent;
    border: none;
    border-bottom: 0.5px solid rgba(240, 238, 232, 0.2);
    color: var(--white);
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.05em;
    padding: 8px 0;
    outline: none;
    resize: none;
    transition: border-color 0.2s ease;
    width: 100%;
  }

  input:focus, textarea:focus {
    border-bottom-color: rgba(240, 238, 232, 0.6);
  }

  button {
    align-self: flex-start;
    background: none;
    border: 0.5px solid rgba(240, 238, 232, 0.2);
    border-radius: 20px;
    color: var(--white-muted);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    margin-top: 8px;
    padding: 10px 28px;
    text-transform: uppercase;
    transition: all 0.25s ease;
  }

  button:hover {
    color: var(--white);
    border-color: rgba(240, 238, 232, 0.6);
  }
</style>