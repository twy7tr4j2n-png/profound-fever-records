---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
  <main class="home">

    <!-- HERO -->
    <section class="hero">
      <div class="album-wrap">
        <a href="#" class="album-link" aria-label="Stream Hooch Mama">
          <img src="/images/hooch-mama.jpg" alt="Hooch Mama" class="album-cover" />
        </a>
      </div>
      <div class="platform-strip">
        <a href="#" class="platform-btn" target="_blank" rel="noopener">Spotify</a>
        <a href="#" class="platform-btn" target="_blank" rel="noopener">Apple Music</a>
        <a href="#" class="platform-btn" target="_blank" rel="noopener">Tidal</a>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="about">
      <p>We are a Latin-ran record label based in San Diego, California. Founded by Angelique Ortega and Jonathan Ventura in 2022, we've become home to writers, artists, producers, audio engineers, and designers striving to connect music and art to its dedicated audience.</p>
    </section>

    <!-- PAST WORKS -->
    <section class="past-works">
      <div class="past-scroll">
        <a href="#" class="past-item"><img src="/images/experiment-619.png" alt="Experiment 619" /></a>
        <a href="#" class="past-item"><img src="/images/backstage.jpg" alt="Backstage" /></a>
        <a href="#" class="past-item"><img src="/images/805.jpg" alt="805" /></a>
        <a href="#" class="past-item"><img src="/images/winter-in-the-city.png" alt="Winter in the City" /></a>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .home {
    min-height: 100vh;
    background: radial-gradient(ellipse at center, var(--black) 0%, var(--purple-edge) 100%);
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 36px;
    padding: 100px 32px 60px;
  }

  .album-wrap {
    animation: float 5s ease-in-out infinite;
  }

  @keyframes float {
    0%   { transform: translateY(0px); }
    50%  { transform: translateY(-16px); }
    100% { transform: translateY(0px); }
  }

  .album-cover {
    width: clamp(240px, 35vw, 420px);
    height: clamp(240px, 35vw, 420px);
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .platform-strip {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .platform-btn {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(240, 238, 232, 0.5);
    border: 0.5px solid rgba(240, 238, 232, 0.2);
    border-radius: 20px;
    padding: 8px 20px;
    transition: all 0.25s ease;
  }

  .platform-btn:hover {
    color: var(--white);
    border-color: rgba(240, 238, 232, 0.6);
  }

  /* ABOUT */
  .about {
    max-width: 480px;
    margin: 0 auto;
    padding: 80px 32px;
    text-align: center;
  }

  .about p {
    font-family: var(--font-serif);
    font-size: clamp(15px, 2vw, 18px);
    font-weight: 300;
    line-height: 1.9;
    color: var(--white-muted);
    letter-spacing: 0.05em;
  }

  /* PAST WORKS */
  .past-works {
    padding: 40px 0 80px;
    border-top: 0.5px solid rgba(240, 238, 232, 0.08);
  }

  .past-scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding: 0 32px;
    scrollbar-width: none;
  }

  .past-scroll::-webkit-scrollbar { display: none; }

  .past-item {
    flex-shrink: 0;
  }

  .past-item img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 3px;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    display: block;
  }

  .past-item:hover img { opacity: 1; }
</style>
