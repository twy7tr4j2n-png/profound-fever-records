---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout>
  <main class="home">

    <section class="hero">

      <!-- CURRENT RELEASE -->
      <div class="current">
        <div class="album-wrap">
          <a href="#" aria-label="Stream Hooch Mama">
            <img src="/images/hooch-mama.jpg" alt="Hooch Mama" class="album-cover" />
          </a>
        </div>
        <div class="track-info">
          <p class="track-title">Hooch Mama</p>
          <p class="track-artist">Astrolique ft. South Boy</p>
        </div>
        <div class="platform-strip">
          <a href="#" class="platform-btn" target="_blank" rel="noopener">Spotify</a>
          <a href="#" class="platform-btn" target="_blank" rel="noopener">Apple Music</a>
          <a href="#" class="platform-btn" target="_blank" rel="noopener">Tidal</a>
        </div>
      </div>

      <!-- PAST RELEASES -->
      <div class="past-works">
        <div class="past-scroll">
          <a href="#" class="past-item"><img src="/images/experiment-619.png" alt="Experiment 619" /></a>
          <a href="#" class="past-item"><img src="/images/backstage.jpg" alt="Backstage" /></a>
          <a href="#" class="past-item"><img src="/images/805.jpg" alt="805" /></a>
          <a href="#" class="past-item"><img src="/images/winter-in-the-city.jpeg" alt="Winter in the City" /></a>
        </div>
      </div>

    </section>

    <!-- ABOUT -->
    <section class="about">
      <p>We are a Latin-ran record label based in San Diego, California. Founded by Angelique Ortega and Jonathan Ventura in 2022, we've become home to writers, artists, producers, audio engineers, and designers striving to connect music and art to its dedicated audience.</p>
    </section>

  </main>
</BaseLayout>

<style>
  .home {
    background: radial-gradient(ellipse at center, var(--black) 0%, var(--purple-edge) 100%);
  }

  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 48px;
    padding: 100px 24px 80px;
  }

  /* CURRENT */
  .current {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .album-wrap {
    animation: float 5s ease-in-out infinite;
  }

  @keyframes float {
    0%   { transform: translateY(0px); }
    50%  { transform: translateY(-14px); }
    100% { transform: translateY(0px); }
  }

  .album-cover {
    width: min(72vw, 400px);
    height: min(72vw, 400px);
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .track-info {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .track-title {
    font-family: var(--font-serif);
    font-size: clamp(22px, 4vw, 34px);
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--white);
  }

  .track-artist {
    font-family: var(--font-sans);
    font-size: clamp(11px, 1.8vw, 13px);
    font-weight: 300;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  .platform-strip {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .platform-btn {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(240, 238, 232, 0.5);
    border: 0.5px solid rgba(240, 238, 232, 0.2);
    border-radius: 20px;
    padding: 8px 20px;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .platform-btn:hover {
    color: var(--white);
    border-color: rgba(240, 238, 232, 0.6);
  }

  /* PAST WORKS */
  .past-works {
    width: 100%;
    border-top: 0.5px solid rgba(240, 238, 232, 0.08);
    padding-top: 32px;
  }

  .past-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none;
    justify-content: center;
    flex-wrap: wrap;
  }

  .past-scroll::-webkit-scrollbar { display: none; }

  .past-item { flex-shrink: 0; }

  .past-item img {
    width: min(20vw, 120px);
    height: min(20vw, 120px);
    object-fit: cover;
    border-radius: 3px;
    opacity: 0.45;
    transition: opacity 0.3s ease;
    display: block;
  }

  .past-item:hover img { opacity: 1; }

  /* ABOUT */
  .about {
    max-width: 480px;
    margin: 0 auto;
    padding: 80px 24px 100px;
    text-align: center;
    border-top: 0.5px solid rgba(240, 238, 232, 0.08);
  }

  .about p {
    font-family: var(--font-serif);
    font-size: clamp(15px, 2vw, 18px);
    font-weight: 300;
    line-height: 1.9;
    color: var(--white-muted);
    letter-spacing: 0.05em;
  }

  /* MOBILE */
  @media (max-width: 480px) {
    .album-cover {
      width: 85vw;
      height: 85vw;
    }

    .past-item img {
      width: 22vw;
      height: 22vw;
    }
  }
</style>