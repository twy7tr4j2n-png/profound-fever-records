---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Jackie Aguirre — Profound Fever Records">
  <main class="roster-page">

    <div class="artist">
      <div class="artist-photo-wrap">
        <img src="/images/jackie-aguirre.jpg" alt="Jackie Aguirre" class="artist-photo" />
      </div>
      <div class="artist-info">
        <p class="artist-label">Profound Fever Records</p>
        <h1 class="artist-name">Jackie Aguirre</h1>
        <p class="artist-role">Visual Artist</p>
        <p class="artist-bio">Jackie Aguirre focuses on 2-dimensional art making with mediums such as oils, watercolors, acrylic, gouache, graphite, and charcoal. Her goal is to educate others about her techniques and knowledge in the arts. She believes art can bring change, movement, inspiration, and self discovery.</p>
        <div class="artist-links">
          <a href="#" target="_blank" rel="noopener">Instagram</a>
          <a href="#" target="_blank" rel="noopener">Portfolio</a>
        </div>
      </div>
    </div>

  </main>
</BaseLayout>

<style>
  .roster-page {
    min-height: 100vh;
    background: radial-gradient(ellipse at center, var(--black) 0%, var(--purple-edge) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 24px 80px;
  }

  .artist {
    display: flex;
    gap: 64px;
    align-items: center;
    max-width: 900px;
    width: 100%;
  }

  .artist-photo-wrap { flex-shrink: 0; }

  .artist-photo {
    width: min(40vw, 340px);
    height: min(40vw, 340px);
    object-fit: cover;
    object-position: top;
    border-radius: 3px;
    display: block;
  }

  .artist-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .artist-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--white-muted);
  }

  .artist-name {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--white);
    line-height: 1;
  }

  .artist-role {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--white-muted);
    margin-top: -8px;
  }

  .artist-bio {
    font-family: var(--font-serif);
    font-size: clamp(14px, 1.8vw, 17px);
    font-weight: 300;
    line-height: 1.85;
    color: rgba(240, 238, 232, 0.6);
    letter-spacing: 0.03em;
    max-width: 480px;
  }

  .artist-links {
    display: flex;
    gap: 20px;
    margin-top: 8px;
  }

  .artist-links a {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--white-muted);
    border-bottom: 0.5px solid rgba(240, 238, 232, 0.2);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .artist-links a:hover {
    color: var(--white);
    border-color: rgba(240, 238, 232, 0.6);
  }

  @media (max-width: 640px) {
    .artist {
      flex-direction: column;
      gap: 32px;
      align-items: flex-start;
    }

    .artist-photo {
      width: 80vw;
      height: 80vw;
    }
  }
</style>